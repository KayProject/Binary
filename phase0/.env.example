# Phase 0 spike — copy to phase0/.env.local and fill in. Never commit the filled file.

# Polygon mainnet RPC (Alchemy / Infura / public)
POLYGON_RPC_URL=

# Celo mainnet RPC (for the bridge leg: USDm swap + CCTP)
CELO_RPC_URL=

# Polymarket Builder API credentials — polymarket.com/settings?tab=builder
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=

# Throwaway EOA standing in for the prod server-managed signer (Turnkey/Privy server
# wallet). Test only, low funds. Leave blank to have the spike generate one on first run.
TEST_EOA_PRIVATE_KEY=

# Polymarket endpoints (defaults; override only if they change)
CLOB_API_URL=https://clob.polymarket.com
RELAYER_URL=https://relayer-v2.polymarket.com/
